{
  "name": "@postrun/react",
  "version": "0.0.0",
  "description": "React provider, hooks, and headless components for the Postrun API",
  "license": "Apache-2.0",
  "homepage": "https://postrun.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/postrun/postrun-js.git",
    "directory": "packages/react"
  },
  "type": "module",
  "files": [
    "dist",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0"
  },
  "dependencies": {
    "@postrun/js": "workspace:*",
    "@tanstack/react-query": "^5.101.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
