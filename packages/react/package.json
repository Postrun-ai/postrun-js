{
  "name": "@postrun/react",
  "version": "0.0.0",
  "description": "React provider, hooks, and headless components for the Postrun API",
  "license": "SEE LICENSE IN ../../LICENSE",
  "homepage": "https://postrun.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/postrun/postrun-js.git",
    "directory": "packages/react"
  },
  "type": "module",
  "files": ["dist", "LICENSE"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0"
  },
  "dependencies": {
    "@postrun/js": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
